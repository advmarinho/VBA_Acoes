Option Explicit

Sub ImportarREM_Santander_SelecionarArquivo_Rapido()

    Dim ws As Worksheet
    Dim caminhoArquivo As String
    Dim fileNum As Integer
    Dim linha As String
    
    Dim ultimaLinha As Long
    Dim idx As Long
    Dim capacidade As Long
    Dim dados() As Variant
    
    Dim nomeBeneficiario As String
    Dim cpf As String
    Dim dataPagamento As String
    Dim valor As Double
    Dim agencia As String
    Dim conta As String
    
    Dim endereco As String
    Dim numero As String
    Dim complemento As String
    Dim bairro As String
    Dim cidade As String
    Dim cep As String
    Dim uf As String
    
    Dim totalArquivo As Double
    
    Dim dlg As FileDialog
    Dim calcAnterior As XlCalculation
    Dim tempoInicio As Double
    
    On Error GoTo TratarErro
    
    tempoInicio = Timer
    
    With Application
        .ScreenUpdating = False
        .EnableEvents = False
        calcAnterior = .Calculation
        .Calculation = xlCalculationManual
        .DisplayStatusBar = True
        .StatusBar = "Selecione o arquivo REM..."
    End With
    
    Set dlg = Application.FileDialog(msoFileDialogFilePicker)
    
    With dlg
        .Title = "Selecione o arquivo REM do Santander"
        .Filters.Clear
        .Filters.Add "Arquivo REM", "*.rem"
        .AllowMultiSelect = False
        
        If .Show = False Then GoTo Finalizar
        
        caminhoArquivo = .SelectedItems(1)
    End With
    
    On Error Resume Next
    Set ws = ThisWorkbook.Sheets("REM Santander")
    If ws Is Nothing Then
        Set ws = ThisWorkbook.Sheets.Add
        ws.Name = "REM Santander"
    End If
    On Error GoTo TratarErro
    
    ws.Cells.Clear
    
    With ws.Range("A2:K2")
        .Interior.Color = RGB(0, 51, 102)
        .Font.Color = RGB(255, 255, 255)
        .Font.Bold = True
        .HorizontalAlignment = xlCenter
    End With
    
    ws.Cells(2, 1).Value = "Nome Beneficiário"
    ws.Cells(2, 2).Value = "CPF"
    ws.Cells(2, 3).Value = "Data Pagamento"
    ws.Cells(2, 4).Value = "Valor"
    ws.Cells(2, 5).Value = "Agência"
    ws.Cells(2, 6).Value = "Conta"
    ws.Cells(2, 7).Value = "Endereço"
    ws.Cells(2, 8).Value = "Bairro"
    ws.Cells(2, 9).Value = "Cidade"
    ws.Cells(2, 10).Value = "CEP"
    ws.Cells(2, 11).Value = "UF"
    
    capacidade = 1000
    ReDim dados(1 To capacidade, 1 To 11)
    idx = 0
    totalArquivo = 0
    
    Application.StatusBar = "Lendo arquivo: " & Dir(caminhoArquivo)
    
    fileNum = FreeFile
    Open caminhoArquivo For Input As fileNum
    
    Do While Not EOF(fileNum)
        Line Input #fileNum, linha
        
        If Len(linha) >= 240 Then
            If Mid$(linha, 8, 1) = "3" Then
                
                If Mid$(linha, 14, 1) = "A" Then
                    
                    agencia = Trim$(Mid$(linha, 24, 5))
                    conta = Trim$(Mid$(linha, 30, 13))
                    nomeBeneficiario = Trim$(Mid$(linha, 44, 30))
                    
                    cpf = Right$(Trim$(Mid$(linha, 74, 20)), 11)
                    dataPagamento = Trim$(Mid$(linha, 94, 8))
                    valor = Val(Trim$(Mid$(linha, 120, 15))) / 100
                    
                    If IsNumeric(cpf) And Len(cpf) = 11 Then
                        cpf = Left$(cpf, 3) & "." & Mid$(cpf, 4, 3) & "." & Mid$(cpf, 7, 3) & "-" & Right$(cpf, 2)
                    Else
                        cpf = ""
                    End If
                    
                    If IsNumeric(dataPagamento) And Len(dataPagamento) = 8 Then
                        dataPagamento = Left$(dataPagamento, 2) & "/" & Mid$(dataPagamento, 3, 2) & "/" & Right$(dataPagamento, 4)
                    Else
                        dataPagamento = ""
                    End If
                    
                ElseIf Mid$(linha, 14, 1) = "B" Then
                    
                    endereco = Trim$(Mid$(linha, 33, 30))
                    numero = Trim$(Mid$(linha, 63, 5))
                    complemento = Trim$(Mid$(linha, 68, 15))
                    bairro = Trim$(Mid$(linha, 83, 15))
                    cidade = Trim$(Mid$(linha, 98, 20))
                    cep = Trim$(Mid$(linha, 118, 8))
                    uf = Trim$(Mid$(linha, 126, 2))
                    
                    If IsNumeric(cep) And Len(cep) = 8 Then
                        cep = Left$(cep, 5) & "-" & Right$(cep, 3)
                    Else
                        cep = ""
                    End If
                    
                    idx = idx + 1
                    
                    If idx > capacidade Then
                        capacidade = capacidade + 1000
                        ReDim Preserve dados(1 To capacidade, 1 To 11)
                    End If
                    
                    dados(idx, 1) = nomeBeneficiario
                    dados(idx, 2) = cpf
                    dados(idx, 3) = dataPagamento
                    dados(idx, 4) = valor
                    dados(idx, 5) = agencia
                    dados(idx, 6) = conta
                    dados(idx, 7) = Trim$(endereco & IIf(numero <> "", ", " & numero, "") & IIf(complemento <> "", " " & complemento, ""))
                    dados(idx, 8) = bairro
                    dados(idx, 9) = cidade
                    dados(idx, 10) = cep
                    dados(idx, 11) = uf
                    
                    totalArquivo = totalArquivo + valor
                End If
            End If
        End If
    Loop
    
    Close fileNum
    
    If idx > 0 Then
        ws.Range("A3").Resize(idx, 11).Value = dados
        
        ultimaLinha = ws.Cells(ws.Rows.Count, 4).End(xlUp).Row
        
        ws.Cells(1, 4).Formula = "=SUM(D3:D" & ultimaLinha & ")"
        ws.Cells(1, 4).Font.Bold = True
        ws.Cells(1, 4).Interior.Color = RGB(255, 255, 153)
        ws.Cells(1, 4).NumberFormat = "#,##0.00"
        
        ws.Columns(4).NumberFormat = "#,##0.00"
        ws.Columns("A:K").AutoFit
    End If
    
    MsgBox "Importação concluída com sucesso!" & vbCrLf & _
           "Registros importados: " & idx & vbCrLf & _
           "Total encontrado: R$ " & Format(totalArquivo, "#,##0.00") & vbCrLf & _
           "Tempo: " & Format(Timer - tempoInicio, "0.00") & " segundos.", _
           vbInformation, "Finalizado"

Finalizar:
    With Application
        .ScreenUpdating = True
        .EnableEvents = True
        .Calculation = calcAnterior
        .StatusBar = False
    End With
    Exit Sub

TratarErro:
    MsgBox "Erro durante a importação: " & Err.Description, vbCritical, "Erro"
    Resume Finalizar

End Sub
