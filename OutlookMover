Option Explicit

Public Sub SalvarEmailsBeneficios_PDFNomeManual()

    Dim objItem As Object
    Dim objMail As Outlook.MailItem

    Dim xlApp As Object
    Dim wb As Object
    Dim ws As Object

    Dim excelFilePath As String
    Dim lastRow As Long

    Dim senderEmail As String
    Dim senderName As String
    Dim senderDisplayName As String
    Dim emailDate As String
    Dim subject As String

    Dim classificationReason As String
    Dim suggestedMatricula As String

    Dim nomePDFBase As String
    Dim pastaDestino As String
    Dim arquivosSalvos As String
    Dim qtdPDF As Long

    excelFilePath = "C:\_RPA\AppMacro\_email_rh_vt.xlsx"

    If Application.ActiveExplorer Is Nothing Then
        MsgBox "Nenhum Explorer ativo no Outlook.", vbExclamation
        Exit Sub
    End If

    If Application.ActiveExplorer.Selection.Count = 0 Then
        MsgBox "Selecione ao menos um e-mail.", vbExclamation
        Exit Sub
    End If

    '================================================
    ' ABRIR EXCEL
    '================================================

    Set xlApp = CreateObject("Excel.Application")

    xlApp.Visible = False
    xlApp.DisplayAlerts = False

    ' Criar pasta se não existir
    Call MkDirRec("C:\_RPA\AppMacro")

    If Dir(excelFilePath) = "" Then

        Set wb = xlApp.Workbooks.Add
        Set ws = wb.Sheets(1)

        Call GarantirCabecalhos(ws)

        wb.SaveAs excelFilePath

    Else

        Set wb = xlApp.Workbooks.Open(excelFilePath)
        Set ws = wb.Sheets(1)

        Call GarantirCabecalhos(ws)

    End If

    '================================================
    ' LOOP NOS EMAILS
    '================================================

    For Each objItem In Application.ActiveExplorer.Selection

        If TypeOf objItem Is Outlook.MailItem Then

            Set objMail = objItem

            senderName = NzTexto(objMail.senderName)
            senderEmail = GetSmtpAddress(objMail)
            senderDisplayName = ""

            If InStr(1, senderEmail, "/O=EXCHANGELABS", vbTextCompare) > 0 Then
                senderDisplayName = senderName
            End If

            emailDate = Format(objMail.sentOn, "yyyy_mm_dd")
            subject = IIf(Trim$(objMail.subject) = "", "Sem_Assunto", objMail.subject)

            suggestedMatricula = FindMatricula(subject)

            If suggestedMatricula = "" Then
                suggestedMatricula = FindMatricula(objMail.Body)
            End If

            classificationReason = InputBox( _
                "Digite a matrícula ou motivo." & vbCrLf & vbCrLf & _
                "Sugestão encontrada: " & suggestedMatricula, _
                "Classificação do E-mail", _
                suggestedMatricula)

            If Trim$(classificationReason) = "" Then
                MsgBox "Classificação obrigatória.", vbExclamation
                GoTo Proximo
            End If

            nomePDFBase = InputBox( _
                "Digite o nome do PDF." & vbCrLf & _
                "Exemplo: ANTONIO SILVA_99999999999", _
                "Nome do PDF", _
                suggestedMatricula)

            nomePDFBase = LimparNomeArquivoBase(nomePDFBase)

            If Trim$(nomePDFBase) = "" Then
                MsgBox "Nome do PDF obrigatório.", vbExclamation
                GoTo Proximo
            End If

            pastaDestino = EscolherPastaOffice()

            If Trim$(pastaDestino) = "" Then
                MsgBox "Pasta não selecionada.", vbExclamation
                GoTo Proximo
            End If

            arquivosSalvos = ""
            qtdPDF = SalvarPDFsDoEmail(objMail, pastaDestino, nomePDFBase, arquivosSalvos)

            If qtdPDF = 0 Then
                MsgBox "Nenhum PDF encontrado.", vbExclamation
                GoTo Proximo
            End If

            lastRow = ws.Cells(ws.Rows.Count, "A").End(-4162).Row + 1

            With ws

                .Cells(lastRow, 1).Value = subject
                .Cells(lastRow, 2).Value = senderEmail
                .Cells(lastRow, 3).Value = senderName
                .Cells(lastRow, 4).Value = emailDate
                .Cells(lastRow, 5).Value = "Atendimento"
                .Cells(lastRow, 6).Value = GetTheme(GetShortSubject(subject))
                .Cells(lastRow, 7).Value = classificationReason
                .Cells(lastRow, 8).Value = senderDisplayName
                .Cells(lastRow, 9).Value = nomePDFBase
                .Cells(lastRow, 10).Value = pastaDestino
                .Cells(lastRow, 11).Value = qtdPDF
                .Cells(lastRow, 12).Value = arquivosSalvos
                .Cells(lastRow, 13).Value = Now

            End With

            objMail.Move Application.Session.GetDefaultFolder(olFolderDeletedItems)

        End If

Proximo:

    Next objItem

    wb.Save
    wb.Close False
    xlApp.Quit

    MsgBox "Processamento concluído.", vbInformation

End Sub

'================================================
' SALVAR PDF
'================================================

Private Function SalvarPDFsDoEmail(ByVal objMail As Outlook.MailItem, _
                                   ByVal pastaDestino As String, _
                                   ByVal nomePDFBase As String, _
                                   ByRef arquivosSalvos As String) As Long

    Dim i As Long
    Dim att As Outlook.attachment
    Dim caminhoFinal As String
    Dim nomeArquivo As String
    Dim contador As Long

    If Dir(pastaDestino, vbDirectory) = "" Then
        MkDirRec pastaDestino
    End If

    For i = 1 To objMail.Attachments.Count

        Set att = objMail.Attachments(i)

        If LCase(Right(att.fileName, 4)) = ".pdf" Then

            contador = contador + 1

            If contador = 1 Then
                nomeArquivo = nomePDFBase & ".pdf"
            Else
                nomeArquivo = nomePDFBase & "_" & contador & ".pdf"
            End If

            caminhoFinal = pastaDestino & "\" & nomeArquivo
            caminhoFinal = GerarNomeUnico(caminhoFinal)

            att.SaveAsFile caminhoFinal

            If arquivosSalvos = "" Then
                arquivosSalvos = caminhoFinal
            Else
                arquivosSalvos = arquivosSalvos & " | " & caminhoFinal
            End If

        End If

    Next i

    SalvarPDFsDoEmail = contador

End Function

'================================================
' ESCOLHER PASTA
'================================================

Private Function EscolherPastaOffice() As String

    Dim xlApp As Object
    Dim fd As Object

    Set xlApp = CreateObject("Excel.Application")
    Set fd = xlApp.FileDialog(4)

    With fd

        .Title = "Selecione a pasta para salvar o PDF"
        .AllowMultiSelect = False

        If .Show = -1 Then
            EscolherPastaOffice = .SelectedItems(1)
        End If

    End With

    xlApp.Quit

End Function

'================================================
' FUNÇÕES AUXILIARES
'================================================

Private Sub GarantirCabecalhos(ws As Object)

    If ws.Cells(1, 1).Value = "" Then

        ws.Cells(1, 1).Value = "Assunto"
        ws.Cells(1, 2).Value = "Email"
        ws.Cells(1, 3).Value = "Nome"
        ws.Cells(1, 4).Value = "Data"
        ws.Cells(1, 5).Value = "Canal"
        ws.Cells(1, 6).Value = "Tema"
        ws.Cells(1, 7).Value = "Classificacao"
        ws.Cells(1, 8).Value = "DisplayName"
        ws.Cells(1, 9).Value = "NomePDF"
        ws.Cells(1, 10).Value = "Pasta"
        ws.Cells(1, 11).Value = "QtdPDF"
        ws.Cells(1, 12).Value = "Arquivos"
        ws.Cells(1, 13).Value = "DataProcessamento"

    End If

End Sub

Private Function FindMatricula(texto As String) As String

    Dim regex As Object

    Set regex = CreateObject("VBScript.RegExp")

    regex.Pattern = "\b\d{4,6}\b"
    regex.Global = True

    If regex.Test(texto) Then
        FindMatricula = regex.Execute(texto)(0)
    End If

End Function

Private Function GetShortSubject(subject As String) As String

    subject = Replace(subject, "RE:", "")
    subject = Replace(subject, "FW:", "")

    GetShortSubject = Left(subject, 40)

End Function

Private Function GetTheme(shortSubject As String) As String

    If InStr(1, shortSubject, "beneficio", vbTextCompare) > 0 Then
        GetTheme = "Beneficios"
    Else
        GetTheme = "Outros"
    End If

End Function

Private Function GetSmtpAddress(mail As Outlook.MailItem) As String

    Dim PR_SMTP_ADDRESS As String

    PR_SMTP_ADDRESS = "http://schemas.microsoft.com/mapi/proptag/0x39FE001E"

    On Error Resume Next

    If mail.SenderEmailType = "EX" Then
        GetSmtpAddress = mail.Sender.PropertyAccessor.GetProperty(PR_SMTP_ADDRESS)
    Else
        GetSmtpAddress = mail.SenderEmailAddress
    End If

End Function

Private Function LimparNomeArquivoBase(texto As String) As String

    Dim invalidos As Variant
    Dim i As Long

    invalidos = Array("\", "/", ":", "*", "?", """", "<", ">", "|")

    For i = 0 To UBound(invalidos)
        texto = Replace(texto, invalidos(i), "_")
    Next i

    LimparNomeArquivoBase = texto

End Function

Private Function GerarNomeUnico(caminho As String) As String

    Dim n As Long
    Dim base As String
    Dim ext As String

    If Dir(caminho) = "" Then
        GerarNomeUnico = caminho
        Exit Function
    End If

    base = Left(caminho, InStrRev(caminho, ".") - 1)
    ext = Mid(caminho, InStrRev(caminho, "."))

    n = 1

    Do
        caminho = base & "_" & n & ext
        n = n + 1
    Loop While Dir(caminho) <> ""

    GerarNomeUnico = caminho

End Function

Private Sub MkDirRec(ByVal caminho As String)

    Dim partes() As String
    Dim atual As String
    Dim i As Long

    partes = Split(caminho, "\")

    atual = partes(0) & "\"

    For i = 1 To UBound(partes)

        atual = atual & partes(i) & "\"

        If Dir(atual, vbDirectory) = "" Then
            MkDir atual
        End If

    Next i

End Sub

Private Function NzTexto(valor As Variant) As String

    If IsNull(valor) Then
        NzTexto = ""
    Else
        NzTexto = CStr(valor)
    End If

End Function

